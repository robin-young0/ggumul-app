{
  "buildCommand": "npm run build:preview",
  "outputDirectory": "dist-preview",
  "installCommand": "npm install",
  "framework": null,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/check-notifications",
      "schedule": "0 * * * *"
    }
  ]
}
